NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# URL pública con protocolo (https://). Si solo pones el host, el build añade https://.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Google OAuth: habilitar en Supabase Dashboard → Authentication → Providers → Google.
# Redirect URLs allowlist: {NEXT_PUBLIC_APP_URL}/auth/callback (+ prod/staging).
# Callback del provider en Google Cloud: https://<project-ref>.supabase.co/auth/v1/callback
# 2FA staff (TOTP): Supabase Dashboard → Authentication → Multi-Factor → App Authenticator ON.
# Flag app: staff_mfa_required (default off) — ver docs/security/00-overview.md §10
# Aviso de beta cerrada en registro/inicio de sesión (0|false|off para desactivar)
NEXT_PUBLIC_MP_BETA_PHASE=1

# E2E jugador (tests/e2e/user-mobile-responsive.spec.ts). Default: seed QA.
# E2E_USER_EMAIL=qa-player@matchpoint.test
# E2E_USER_PASSWORD=QaTest1234!
RESEND_API_KEY=re_xxx
EMAIL_FROM=MATCHPOINT <notif@matchpoint.top>
# Cron Vercel: vercel.json usa horarios diarios (Hobby). En Pro puedes usar */5 * * * *.
CRON_SECRET=cambiame_a_un_secreto_largo
# LOPDP — datos registrales del responsable (publicar en /legal/privacidad)
# MP_LEGAL_NAME=MATCHPOINT Ecuador S.A.S.
# MP_LEGAL_RUC=179XXXXXXXXX001
# MP_LEGAL_ADDRESS=Av. Ejemplo N12-34, Quito, Ecuador
# MP_LEGAL_REPRESENTATIVE=Nombre Apellido
# GET /api/health — Bearer o ?token= (en prod es obligatorio)
HEALTH_SECRET=cambiame_otro_secreto_largo

# PSP piloto (flag psp_checkout_enabled default off). Webhooks: /api/webhooks/stripe | /api/webhooks/mercadopago
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# MP_ACCESS_TOKEN=APP_USR-...
# MP_WEBHOOK_SECRET=...
# PSP_DEFAULT_PROVIDER=stripe
