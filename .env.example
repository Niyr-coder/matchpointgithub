NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# URL pública con protocolo (https://). Si solo pones el host, el build añade https://.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E2E jugador (tests/e2e/user-mobile-responsive.spec.ts). Default: seed QA.
# E2E_USER_EMAIL=qa-player@matchpoint.test
# E2E_USER_PASSWORD=QaTest1234!
RESEND_API_KEY=re_xxx
EMAIL_FROM=MATCHPOINT <notif@matchpoint.top>
# Cron: GET/POST /api/cron/dispatch-email, /api/cron/giveaway-draws y /api/cron/dispatch-broadcasts (cada 5 min recomendado)
CRON_SECRET=cambiame_a_un_secreto_largo
