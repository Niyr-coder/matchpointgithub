# MatchPoint · variables de entorno (valores ejemplo, no de producción)
# Copia este archivo a .env.local y reemplaza los valores.

# Supabase (cliente público + service role server-only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL base de la app (usada para construir enlaces absolutos en correos)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (dispatcher de correo: /api/cron/dispatch-email)
RESEND_API_KEY=re_xxx
EMAIL_FROM=MatchPoint <notif@matchpoint.top>

# Secreto para autenticar invocaciones de endpoints /api/cron/*
CRON_SECRET=cambiame_a_un_secreto_largo
